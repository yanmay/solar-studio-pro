# SolarScan AI — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# PUBLIC — these are embedded in the browser bundle at build time
# Prefix VITE_ means the value is visible to users. Only put non-secret keys here.
VITE_GOOGLE_MAPS_TILE_KEY=your_google_maps_tile_api_key_here
VITE_API_BASE_URL=http://localhost:5173

# SERVER ONLY — consumed by Vercel Edge Functions, never sent to browser
GOOGLE_GEOCODING_KEY=your_google_geocoding_key_here
NASA_POWER_BASE_URL=https://power.larc.nasa.gov
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# TESTING
PLAYWRIGHT_BASE_URL=http://localhost:5173

# v1.1 — add these when user accounts launch
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# v1.2 — Sentry and Lead Gen email configurations
VITE_SENTRY_DSN=your_sentry_dsn_here
RESEND_API_KEY=your_resend_api_key_here
LEADS_EMAIL=your_installer_leads_destination_email_here

