    "faire-octave": {
      "$value": "Faire Octave",
      "$type": "fontFamily",
      "$description": "Display and section headings only. The serif appears sparingly — two sizes, one weight — to mark narrative moments (hero headline, compliance headline, about headline). Light-weight serif against sans-serif body creates a magazine/editorial cadence; the thin strokes make 74px feel humane rather than corporate."
    },
    "suisse-intl": {
      "$value": "Suisse Int'l",
      "$type": "fontFamily",
      "$description": "Body, UI, nav, buttons, badges, and the 56px hero headline. Weight 300 is the default for larger sizes (hero, subheadings) — the anti-convention choice of a light grotesque for a 56px headline makes the page feel airy and unhurried. Weight 400 handles everything 18px and below. The consistent -0.03em tracking across all sizes tightens the grotesque into a refined, considered voice."
    }
